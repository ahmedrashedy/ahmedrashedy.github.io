---
import '../styles/global.css';
import { site } from '../data/cv';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} — ${site.role}`,
  description = site.hero.sub,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": site.name,
  "alternateName": ["Ahmed Rashedy", "أحمد رشيدي", "Ahmed Rashedy Mohammed"],
  "jobTitle": site.role,
  "description": description,
  "email": `mailto:${site.email}`,
  "telephone": site.phone,
  "url": Astro.site?.toString(),
  "image": new URL('/og-image.svg', Astro.site).toString(),
  "address": { "@type": "PostalAddress", "addressLocality": "Cairo", "addressCountry": "EG" },
  "sameAs": [site.linkedin, site.github],
  "knowsAbout": [
    "Odoo ERP",
    "Odoo Implementation",
    "Odoo Functional Consulting",
    "ERP Project Management",
    "Odoo MRP",
    "Odoo POS",
    "Odoo eCommerce",
    "PMP Methodologies",
    "Business Transformation",
    "Manufacturing",
    "Retail",
    "Hospitality"
  ],
  "knowsLanguage": ["en", "ar"],
  "worksFor": { "@type": "Organization", "name": "Independent ERP Consultant" },
};

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": `${site.name} — Odoo Delivery Services`,
  "description": "End-to-end Odoo ERP delivery: pre-sales, implementation, optimization, and fractional PM leadership.",
  "url": Astro.site?.toString(),
  "provider": { "@type": "Person", "name": site.name, "email": site.email, "telephone": site.phone },
  "areaServed": ["EG", "MENA", "KW"],
  "serviceType": ["ERP Implementation", "Odoo Functional Consulting", "Project Management"],
  "priceRange": "$$",
  "offers": site.services.map((s) => ({
    "@type": "Offer",
    "name": s.title,
    "description": s.summary,
    "category": s.title,
  })),
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": site.faq.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a },
  })),
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": Astro.site?.toString() },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": `${Astro.site}#services` },
    { "@type": "ListItem", "position": 3, "name": "Portfolio", "item": `${Astro.site}#portfolio` },
    { "@type": "ListItem", "position": 4, "name": "Contact", "item": `${Astro.site}#contact` },
  ],
};

const keywords = [
  "Ahmed Rashedy",
  "Ahmed Rashedy Mohammed",
  "أحمد رشيدي",
  "Odoo Project Manager",
  "Odoo Implementer",
  "Odoo Functional Consultant",
  "Odoo Implementation",
  "ERP Delivery",
  "ERP Project Manager",
  "Odoo MRP",
  "Odoo eCommerce",
  "Odoo POS",
  "Manufacturing ERP",
  "Retail ERP",
  "تنفيذ أودو",
  "مدير مشروع أودو",
  "استشاري أودو",
  "Egypt",
  "Cairo",
  "Middle East",
].join(", ");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0B2545" />
    <meta name="color-scheme" content="light" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="googlebot" content="index,follow" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={new URL('/og-image.svg', Astro.site).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} — ${site.role}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.svg', Astro.site).toString()} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@500;600;700&family=Inter:wght@400;500;600&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </head>
  <body class="min-h-screen flex flex-col js">
    <slot />

    <script>
      document.documentElement.classList.add('js');
      document.body.classList.add('js');

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

      const nav = document.getElementById('site-nav');
      const onScroll = () => {
        if (!nav) return;
        if (window.scrollY > 8) nav.classList.add('is-scrolled');
        else nav.classList.remove('is-scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      const sections = document.querySelectorAll<HTMLElement>('main section[id]');
      const navLinks = document.querySelectorAll<HTMLAnchorElement>('#site-nav a[href^="#"]');
      const spyObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              navLinks.forEach((link) => {
                const isActive = link.getAttribute('href') === `#${id}`;
                link.classList.toggle('is-active', isActive);
              });
            }
          }
        },
        { rootMargin: '-40% 0px -55% 0px' }
      );
      sections.forEach((s) => spyObserver.observe(s));

      const cardLinks = document.querySelectorAll<HTMLAnchorElement>('a[data-service]');
      cardLinks.forEach((card) => {
        card.addEventListener('click', (e) => {
          const href = card.getAttribute('href') || '';
          const targetId = 'contact';
          const target = document.getElementById(targetId);
          if (!target) return;
          e.preventDefault();
          const hashWithQuery = href.startsWith('#') ? href : `#${targetId}`;
          if (window.location.hash !== hashWithQuery) {
            history.replaceState(null, '', hashWithQuery);
          }
          const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          target.scrollIntoView({ behavior: prefersReduced ? 'auto' : 'smooth', block: 'start' });
          window.dispatchEvent(new HashChangeEvent('hashchange'));
        });
      });
    </script>
  </body>
</html>
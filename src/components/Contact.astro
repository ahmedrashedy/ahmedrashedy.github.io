---
import { site } from '../data/cv';
const FORMSPREE_ID = 'YOUR_FORMSPREE_ID';
const FORM_ACTION = `https://formsubmit.co/ajax/${site.email}`;
---

<section id="contact" class="section bg-soft border-t border-border">
  <div class="container-narrow">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="reveal lg:col-span-5">
        <p class="eyebrow">Start a Conversation</p>
        <h2 class="mt-4 h2 text-balance">Tell me about your project.</h2>
        <p class="mt-5 lede">
          The more context you share — industry, modules of interest, current pain — the more useful our first call will be.
        </p>

        <ul class="mt-8 space-y-5">
          <li class="flex items-start gap-3">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-md bg-white text-sky-700 ring-1 ring-sky/20">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </span>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-slatey">Email</p>
              <a href={`mailto:${site.email}`} class="mt-0.5 block font-medium text-ink hover:text-sky break-all">{site.email}</a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-md bg-white text-sky-700 ring-1 ring-sky/20">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </span>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-slatey">Phone / WhatsApp</p>
              <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="mt-0.5 block font-medium text-ink hover:text-sky">{site.phoneDisplay}</a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-md bg-white text-sky-700 ring-1 ring-sky/20">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.61 0 4.28 2.38 4.28 5.47v6.27zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z" />
              </svg>
            </span>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-slatey">LinkedIn</p>
              <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="mt-0.5 block font-medium text-ink hover:text-sky break-all">in/ahmed-rashedy-mohammed</a>
            </div>
          </li>
        </ul>

        <div class="mt-10 rounded-xl border border-border bg-white p-5 text-xs leading-relaxed text-slatey">
          <p class="font-semibold text-ink">What happens next?</p>
          <p class="mt-1.5">Within 24 hours you'll get a reply with two or three proposed slots for a 30-min scoping call — no commitment, no sales pitch.</p>
        </div>
      </div>

      <div class="reveal lg:col-span-7">
        <form
          action={FORM_ACTION}
          method="POST"
          class="space-y-5 rounded-xl border border-border bg-white p-6 sm:p-8 shadow-[0_8px_30px_-20px_rgba(11,37,69,0.15)]"
          id="contact-form"
          data-email={site.email}
        >
          <input type="hidden" name="_subject" value={`New enquiry: ahmedrashedy.github.io — {{interest}}`} />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_autoresponse" value="Thanks for reaching out — I'll reply within 24 hours. — Ahmed" />

          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div>
              <label for="name" class="block text-sm font-medium text-ink">Name</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                autocomplete="name"
                class="mt-1.5 block w-full rounded-md border border-border bg-white px-3.5 py-2.5 text-sm text-ink placeholder:text-slatey/60 focus:border-ink focus:outline-none focus:ring-1 focus:ring-ink"
                placeholder="Your full name"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-ink">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                autocomplete="email"
                class="mt-1.5 block w-full rounded-md border border-border bg-white px-3.5 py-2.5 text-sm text-ink placeholder:text-slatey/60 focus:border-ink focus:outline-none focus:ring-1 focus:ring-ink"
                placeholder="you@company.com"
              />
            </div>
          </div>
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div>
              <label for="phone" class="block text-sm font-medium text-ink">Phone / WhatsApp <span class="text-slatey font-normal">(optional)</span></label>
              <input
                id="phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                class="mt-1.5 block w-full rounded-md border border-border bg-white px-3.5 py-2.5 text-sm text-ink placeholder:text-slatey/60 focus:border-ink focus:outline-none focus:ring-1 focus:ring-ink"
                placeholder="+20 ..."
              />
            </div>
            <div>
              <label for="company" class="block text-sm font-medium text-ink">Company</label>
              <input
                id="company"
                name="company"
                type="text"
                class="mt-1.5 block w-full rounded-md border border-border bg-white px-3.5 py-2.5 text-sm text-ink placeholder:text-slatey/60 focus:border-ink focus:outline-none focus:ring-1 focus:ring-ink"
                placeholder="Optional"
              />
            </div>
          </div>
          <div>
            <label for="interest" class="block text-sm font-medium text-ink">I'm interested in</label>
            <select
              id="interest"
              name="interest"
              class="mt-1.5 block w-full rounded-md border border-border bg-white px-3.5 py-2.5 text-sm text-ink focus:border-ink focus:outline-none focus:ring-1 focus:ring-ink"
            >
              <option value="Pre-Sales &amp; Scoping">Pre-Sales &amp; Scoping</option>
              <option value="End-to-End Implementation">End-to-End Implementation</option>
              <option value="Post-Go-Live Optimization">Post-Go-Live Optimization</option>
              <option value="Fractional ERP Leadership">Fractional ERP Leadership</option>
              <option value="Not sure yet">Not sure yet</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-ink">Tell me about your project</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="mt-1.5 block w-full rounded-md border border-border bg-white px-3.5 py-2.5 text-sm text-ink placeholder:text-slatey/60 focus:border-ink focus:outline-none focus:ring-1 focus:ring-ink"
              placeholder="Industry, current pain points, modules you're evaluating, timeline — anything that helps me prepare for our call."
            ></textarea>
          </div>
          <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-xs text-slatey">Reply within 24 hours on business days.</p>
            <button type="submit" class="btn-primary w-full sm:w-auto" id="submit-btn">
              <span id="submit-label">Send Message</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
              </svg>
            </button>
          </div>
          <p class="text-[11px] text-slatey/80">
            Sending submits directly to <span class="font-medium text-ink">{site.email}</span>. No signup, no mail client — just a reply.
          </p>
          <p id="form-status" class="text-sm" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');
  const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const label = document.getElementById('submit-label');
  const select = document.getElementById('interest') as HTMLSelectElement | null;

  function applyServiceFromUrl() {
    const hash = window.location.hash;
    if (!hash.startsWith('#contact')) return;
    const queryIndex = hash.indexOf('?');
    if (queryIndex === -1) return;
    const params = new URLSearchParams(hash.slice(queryIndex + 1));
    const service = params.get('service');
    if (!service) return;
    if (!select) return;
    const map: Record<string, string> = {
      presales: 'Pre-Sales & Scoping',
      implementation: 'End-to-End Implementation',
      optimization: 'Post-Go-Live Optimization',
      consulting: 'Fractional ERP Leadership',
      unsure: 'Not sure yet',
    };
    const label = map[service] || map.presales;
    const option = Array.from(select.options).find((o) => o.text.trim() === label);
    if (option) {
      select.value = option.value;
      setTimeout(() => {
        const msg = document.getElementById('message');
        if (msg instanceof HTMLTextAreaElement) msg.focus();
      }, 700);
    }
  }

  applyServiceFromUrl();
  window.addEventListener('hashchange', applyServiceFromUrl);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn || !status) return;

    const originalLabel = label?.textContent || 'Send Message';

    btn.disabled = true;
    if (label) label.textContent = 'Sending...';
    status.textContent = '';
    status.className = 'text-sm text-slatey';

    try {
      const data = new FormData(form);
      const interestRaw = data.get('interest');
      const interest = typeof interestRaw === 'string' ? interestRaw : '';
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        const json = await res.json().catch(() => null);
        if (json && (json.success === 'true' || json.success === true || json.message)) {
          status.textContent = `Message sent. Check ${form.dataset.email} for a confirmation.`;
          status.className = 'text-sm text-green-600 font-medium';
          form.reset();
        } else {
          status.textContent = 'Thanks — your message is on its way. I will reply within 24 hours.';
          status.className = 'text-sm text-green-600 font-medium';
          form.reset();
        }
      } else if (res.status === 404 || res.status === 400) {
        status.textContent = 'Form not yet activated. First-time setup required — check your email inbox for an activation link from formsubmit.co.';
        status.className = 'text-sm text-amber-600';
      } else {
        throw new Error(`HTTP ${res.status}`);
      }
    } catch {
      status.innerHTML = `Something went wrong. If this persists, email me directly: <a class="font-medium text-sky underline" href="mailto:${form.dataset.email}">${form.dataset.email}</a>`;
      status.className = 'text-sm text-red-600';
    } finally {
      btn.disabled = false;
      if (label) label.textContent = originalLabel;
    }
  });
</script>

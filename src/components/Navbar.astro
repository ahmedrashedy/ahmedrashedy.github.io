---
const links = [
  { href: '#services', label: 'Services' },
  { href: '#process', label: 'Process' },
  { href: '#portfolio', label: 'Portfolio' },
  { href: '#industries', label: 'Industries' },
  { href: '#about', label: 'About' },
  { href: '#contact', label: 'Contact' },
];
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent bg-white/0 backdrop-blur-0 transition-all duration-300 [&.is-scrolled]:border-border [&.is-scrolled]:bg-white/85 [&.is-scrolled]:backdrop-blur-md [&.is-scrolled]:shadow-[0_1px_0_rgba(15,23,42,0.04)]"
>
  <div class="container-narrow flex h-16 items-center justify-between">
    <a href="#top" class="flex items-center gap-2.5 font-display font-semibold tracking-tight text-ink">
      <span class="grid h-9 w-9 place-items-center overflow-hidden rounded-full bg-ink ring-2 ring-white shadow-sm">
        <img
          src="/brand/avatar-portrait.png"
          alt="Ahmed Rashedy"
          class="h-full w-full object-cover"
          loading="eager"
          width="36"
          height="36"
        />
      </span>
      <span class="hidden sm:inline">Ahmed Rashedy</span>
    </a>

    <nav class="hidden md:flex items-center gap-7">
      {links.map((link) => (
        <a
          href={link.href}
          class="relative text-sm font-medium text-slatey transition-colors hover:text-ink [&.is-active]:text-ink [&.is-active]:font-semibold"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href="#contact" class="btn-primary !py-2 !px-4 text-xs">
        Book a Call
      </a>
      <button
        id="mobile-menu-btn"
        class="md:hidden grid h-9 w-9 place-items-center rounded-md border border-border text-ink"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-border bg-white"
  >
    <nav class="container-narrow flex flex-col py-3">
      {links.map((link) => (
        <a href={link.href} class="mobile-link py-2.5 text-sm font-medium text-slatey hover:text-ink">{link.label}</a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll<HTMLAnchorElement>('.mobile-link');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
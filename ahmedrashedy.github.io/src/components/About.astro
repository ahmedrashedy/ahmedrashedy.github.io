---
import { site } from '../data/cv';
---

<section id="about" class="section">
  <div class="container-narrow">
    <div class="reveal grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-5">
        <p class="eyebrow">About</p>
        <h2 class="mt-4 h2 text-balance">
          The senior PM your team will actually want in the room.
        </h2>
      </div>
      <div class="lg:col-span-7 space-y-5">
        <p class="text-base sm:text-lg leading-relaxed text-slatey">{site.about.intro}</p>

        <ul class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
          {site.about.differentiators.map((d) => (
            <li class="flex items-start gap-3 rounded-lg border border-border bg-soft p-4">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-sky" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span class="text-sm leading-relaxed text-ink">{d}</span>
            </li>
          ))}
        </ul>

        <div class="pt-6">
          <a href="#contact" class="btn-primary">Work with me</a>
        </div>
      </div>
    </div>
  </div>
</section>
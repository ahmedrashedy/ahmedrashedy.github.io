---
import { site } from '../data/cv';
---

<section id="portfolio" class="section">
  <div class="container-narrow">
    <div class="reveal mb-14 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-xl">
        <p class="eyebrow">Selected Work</p>
        <h2 class="mt-4 h2 text-balance">Outcomes I have shipped, not just projects I have staffed.</h2>
      </div>
      <p class="text-sm text-slatey sm:max-w-xs">
        A cross-section of recent engagements, anonymised where appropriate. Detailed case studies available on request.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-5 lg:grid-cols-3">
      {site.caseStudies.map((c, i) => (
        <article class={`reveal card-hover flex flex-col h-full ${c.featured ? 'lg:col-span-1 ring-1 ring-sky/30' : ''}`}>
          <div class="flex items-start justify-between gap-3 text-xs">
            <span class="font-semibold uppercase tracking-wider text-sky-700">Case 0{i + 1}</span>
            <span class="pill-sky">{c.industry}</span>
          </div>

          <h3 class="mt-5 font-display text-xl font-semibold text-ink">{c.client}</h3>
          <p class="mt-1 text-xs text-slatey">{c.duration} · {c.scope}</p>

          <dl class="mt-5 grid grid-cols-3 gap-2 border-y border-border py-4">
            {c.metrics.map((m) => (
              <div class="text-center">
                <dt class="text-[10px] font-medium uppercase tracking-wider text-slatey">{m.label}</dt>
                <dd class="mt-1 font-display text-sm font-semibold text-ink">{m.value}</dd>
              </div>
            ))}
          </dl>

          <div class="mt-4 space-y-3 text-[13.5px] leading-relaxed text-slatey">
            <div>
              <p class="text-[11px] font-semibold uppercase tracking-wider text-ink">Challenge</p>
              <p class="mt-1">{c.challenge}</p>
            </div>
            <div>
              <p class="text-[11px] font-semibold uppercase tracking-wider text-ink">Approach</p>
              <p class="mt-1">{c.solution}</p>
            </div>
            <div>
              <p class="text-[11px] font-semibold uppercase tracking-wider text-sky-700">Outcome</p>
              <p class="mt-1 text-ink/90 font-medium">{c.result}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
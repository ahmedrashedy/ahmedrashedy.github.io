---
import { site } from '../data/cv';

const icons: Record<string, string> = {
  factory: '<path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V3a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v17z"/>',
  store: '<path d="M3 9l1-5h16l1 5"/><path d="M5 9v11a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9"/><path d="M9 21V13h6v8"/>',
  'shopping-cart': '<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>',
  truck: '<rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>',
  briefcase: '<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
  utensils: '<path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>',
};
---

<section id="industries" class="section section-soft border-y border-border">
  <div class="container-narrow">
    <div class="reveal mb-14 max-w-2xl">
      <p class="eyebrow">Industries Served</p>
      <h2 class="mt-4 h2 text-balance">Deep domain knowledge across the verticals that adopt Odoo most aggressively.</h2>
    </div>

    <div class="reveal grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {site.industries.map((ind) => (
        <article class="group flex items-start gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-sky/40">
          <div class="grid h-11 w-11 shrink-0 place-items-center rounded-lg bg-sky/10 text-sky-700 transition-colors group-hover:bg-sky group-hover:text-white">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[ind.icon]} />
          </div>
          <div class="min-w-0 flex-1">
            <h3 class="font-display text-base font-semibold text-ink">{ind.name}</h3>
            <ul class="mt-2 space-y-1 text-xs leading-relaxed text-slatey">
              {ind.highlights.map((h) => (
                <li class="flex items-start gap-1.5">
                  <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-sky" aria-hidden="true"></span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
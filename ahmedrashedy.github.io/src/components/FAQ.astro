---
import { site } from '../data/cv';
---

<section id="faq" class="section">
  <div class="container-narrow">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-4">
        <p class="eyebrow">FAQ</p>
        <h2 class="mt-4 h2 text-balance">Quick answers to common questions.</h2>
        <p class="mt-5 text-sm text-slatey">
          If yours is not here, send it across on the contact form — most replies go out within a day.
        </p>
      </div>

      <div class="lg:col-span-8">
        <div class="reveal divide-y divide-border rounded-xl border border-border bg-white">
          {site.faq.map((item) => (
            <details class="faq-item group px-6">
              <summary>
                <span class="text-base sm:text-[17px] font-medium">{item.q}</span>
                <span class="icon grid h-7 w-7 shrink-0 place-items-center rounded-full bg-sky/10 text-sky transition-transform duration-300">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                  </svg>
                </span>
              </summary>
              <p class="pb-5 text-[15px] leading-relaxed text-slatey">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>